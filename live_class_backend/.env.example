# Node live classroom backend (.env)
# Copy to `.env` and replace placeholder values before production deploy.

NODE_ENV=development
PORT=8080
NODE_ID=

# Local development fallbacks. Keep these false in production.
STORAGE_DRIVER=memory
ALLOW_IN_MEMORY_STORAGE=true
ALLOW_MISSING_REDIS=true
ALLOW_MISSING_LIVEKIT=true

# Shared infrastructure
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lalacore_omega
DATABASE_MAX_CONNECTIONS=20
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_SSL=false
REDIS_URL=redis://localhost:6379/0
REDIS_CHANNEL=live_classroom_events

# Auth / tokening
JWT_SECRET=change-me-local-jwt-secret
JWT_ISSUER=live-class-backend
JWT_AUDIENCE=live-classroom-clients
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_MS=2592000000

# Seed users for local development
DEFAULT_TEACHER_ID=teacher_01
DEFAULT_TEACHER_NAME=Dr Sharma
DEFAULT_TEACHER_EMAIL=teacher@example.com
DEFAULT_TEACHER_PASSWORD=change-me-local-teacher-password
DEFAULT_TEACHER_PASSWORD_HASH=
DEFAULT_STUDENT_ID=student_01
DEFAULT_STUDENT_NAME=Student One
DEFAULT_STUDENT_EMAIL=student@example.com
DEFAULT_STUDENT_PASSWORD=change-me-local-student-password
DEFAULT_STUDENT_PASSWORD_HASH=

# LiveKit media
LIVEKIT_URL=
LIVEKIT_API_KEY=replace-me-livekit-api-key
LIVEKIT_API_SECRET=change-me-livekit-api-secret
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_HTTP_URL=http://localhost:7880
# In production you can usually set only LIVEKIT_URL=wss://your-project.livekit.cloud
# and omit LIVEKIT_HTTP_URL. The backend derives https://... automatically.
LIVEKIT_TOKEN_TTL=2h
LIVEKIT_RECORDING_FILE_PREFIX=recordings
LIVEKIT_ROOM_EMPTY_TIMEOUT=300

# AI worker bridge
AI_PIPELINE_BASE_URL=http://localhost:8000
AI_PIPELINE_API_KEY=

# Optional YouTube replay publishing
# Set YOUTUBE_UPLOAD_ENABLED=true to publish completed class recordings to YouTube.
# Use either a short-lived YOUTUBE_ACCESS_TOKEN or the refresh-token trio below.
YOUTUBE_UPLOAD_ENABLED=false
YOUTUBE_UPLOAD_REQUIRED=false
YOUTUBE_ACCESS_TOKEN=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=unlisted
YOUTUBE_CATEGORY_ID=27
YOUTUBE_DEFAULT_TAGS=jee,live-class,lalacore
YOUTUBE_NOTIFY_SUBSCRIBERS=false
YOUTUBE_MADE_FOR_KIDS=false
# When LiveKit gives the worker a relative recording path such as recordings/class/file.mp4,
# point this at a CDN/object-store base so the worker can fetch the mp4 before upload.
RECORDING_PUBLIC_BASE_URL=
# Optional override for resolving relative local file paths on disk.
RECORDING_WORKDIR=

# Classroom defaults
DEFAULT_CLASS_ID=physics_live_01
DEFAULT_CLASS_TITLE=JEE Live Class
DEFAULT_WAITING_ROOM_ENABLED=true

# Runtime tuning
RECONNECT_GRACE_PERIOD_MS=30000
RECONNECT_INITIAL_DELAY_MS=1000
RECONNECT_MAX_DELAY_MS=30000
RECONNECT_BACKOFF_MULTIPLIER=2
RECONNECT_JITTER_RATIO=0.25
WEBSOCKET_REPLAY_LIMIT=2000
IDEMPOTENCY_TTL_MS=86400000
IDEMPOTENCY_WAIT_TIMEOUT_MS=30000
RECORDING_QUEUE_NAME=recording-processing
RECORDING_WORKER_CONCURRENCY=4
RECORDING_JOB_ATTEMPTS=5
RECORDING_JOB_BACKOFF_MS=1000
