{
  "name": "live-class-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Authoritative backend for live classroom control, state sync, and LiveKit integration.",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "check": "node --check src/server.js",
    "test:unit": "node --test test/**/*.test.js",
    "worker": "node src/workers/recordingWorker.js",
    "load:http": "k6 run load/k6-classroom.js",
    "load:ws": "node load/ws-reconnect-storm.mjs"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.53.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.53.0",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.53.0",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.9",
    "express": "^4.21.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.15.0",
    "pg": "^8.13.1",
    "redis": "^4.7.0",
    "ws": "^8.18.0"
  }
}
